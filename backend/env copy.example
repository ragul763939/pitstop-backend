# PitStop Backend — Environment Variables
# Copy this to .env and fill in your values

PORT=3001
FRONTEND_URL=http://localhost:3000

# Production: set to your Netlify/Vercel URL
# FRONTEND_URL=https://your-pitstop-app.netlify.app

# Optional: Razorpay (payment gateway)
RAZORPAY_KEY_ID=your_key_here
RAZORPAY_KEY_SECRET=your_secret_here

# Optional: Twilio (SMS for SOS)
TWILIO_SID=your_sid_here
TWILIO_AUTH_TOKEN=your_token_here
TWILIO_PHONE=+1234567890
